#!/bin/sh

. /lib/blue-merle/functions.sh
. /lib/functions/modem.sh

STATE_DIR="/etc/blue-merle"
STATE_FILE="${STATE_DIR}/rf-guard.state"
RUNTIME_DIR="/tmp/blue-merle"
LOCK_FILE="${RUNTIME_DIR}/rf-guard.lock"
POLL_INTERVAL=2
MESSAGE_DELAY=1
QPOWD_REBOOT_WAIT=25
MODEM_READY_TIMEOUT=120
MODEM_SOFT_RESTART_WAIT=8
SIM_RECOVERY_INTERVAL=30

CURRENT_SIM_ID=""
SIM_REMOVED=0

display_msg() {
	# Send message to router OLED display via MCU serial port.
	# Display is 16 chars wide; text wraps automatically.
	echo "{\"msg\": \"$1\"}" > /dev/ttyS0 2>/dev/null || true
}

log_step() {
	local message="$1"
	logger -p notice -t blue-merle-rf-guard "$message"
	echo "[blue-merle-rf-guard] $message"
	display_msg "$message"
	sleep "$MESSAGE_DELAY"
}

modem_cmd() {
	local bus
	bus="$(get_modem_bus 2>/dev/null)"
	if [ -n "$bus" ]; then
		gl_modem -B "$bus" AT "$1"
	else
		gl_modem AT "$1"
	fi
}

set_rf_off() {
	local attempt=0
	while [ "$attempt" -lt 5 ]; do
		if modem_cmd "AT+CFUN=4" | grep -q "OK"; then
			return 0
		fi
		attempt=$((attempt + 1))
		sleep 1
	done
	return 1
}

set_rf_on() {
	if modem_cmd "AT+CFUN=1" | grep -q "OK"; then
		return 0
	fi
	return 1
}

read_iccid_raw() {
	modem_cmd "AT+CCID" 2>/dev/null | grep -o -E '[0-9]{18,22}' | head -n1
}

read_imsi_raw() {
	modem_cmd "AT+CIMI" 2>/dev/null | grep -o -E '[0-9]{6,15}' | head -n1
}

read_imei_raw() {
	modem_cmd "AT+GSN" 2>/dev/null | grep -o -E '[0-9]{14,15}' | head -n1
}

get_sim_id() {
	local iccid
	local imsi
	iccid="$(read_iccid_raw)"
	if [ -n "$iccid" ]; then
		echo "iccid:${iccid}"
		return 0
	fi

	imsi="$(read_imsi_raw)"
	if [ -n "$imsi" ]; then
		echo "imsi:${imsi}"
		return 0
	fi

	return 1
}

load_state() {
	if [ -f "$STATE_FILE" ]; then
		. "$STATE_FILE"
	fi
}

save_state() {
	local sim_id="$1"
	local imei="$2"
	mkdir -p "$STATE_DIR"
	cat > "$STATE_FILE" <<EOF
STATE_SIM_ID='$sim_id'
STATE_IMEI='$imei'
STATE_EVER_SEEN_SIM='1'
EOF
}

reset_apn() {
	local bus
	local modem_iface

	bus="$(get_modem_bus 2>/dev/null)"
	modem_iface="$(get_modem_iface "$bus" 2>/dev/null)"

	if [ -n "$modem_iface" ]; then
		uci -q delete "network.${modem_iface}.apn"
		uci -q delete "network.${modem_iface}.apns"
		uci commit network
		ubus call "network.interface.${modem_iface}" down >/dev/null 2>&1
		sleep 1
		ubus call "network.interface.${modem_iface}" up >/dev/null 2>&1
	fi

	modem_cmd 'AT+CGDCONT=1,"IPV4V6",""' >/dev/null 2>&1
	modem_cmd 'AT+CGDCONT=2,"IPV4V6",""' >/dev/null 2>&1
	modem_cmd 'AT+CGDCONT=3,"IPV4V6",""' >/dev/null 2>&1
}

apply_auto_apn() {
	local bus
	local modem_iface
	local attempt=0

	bus="$(get_modem_bus 2>/dev/null)"
	modem_iface="$(get_modem_iface "$bus" 2>/dev/null)"

	if [ -z "$bus" ]; then
		log_step "Auto APN: modem bus not found."
		return 1
	fi

	while [ "$attempt" -lt 3 ]; do
		if gl_modem -B "$bus" connect-auto >/dev/null 2>&1; then
			log_step "Auto APN applied by modem service."
			break
		fi
		attempt=$((attempt + 1))
		sleep 2
	done

	if [ "$attempt" -ge 3 ]; then
		log_step "Auto APN command failed after retries."
		return 1
	fi

	if [ -n "$modem_iface" ]; then
		ubus call "network.interface.${modem_iface}" down >/dev/null 2>&1
		sleep 2
		ubus call "network.interface.${modem_iface}" up >/dev/null 2>&1
		log_step "Modem interface restarted after auto APN."
	fi

	return 0
}

wait_for_modem_ready() {
	local waited=0
	until modem_cmd "AT" | grep -q "OK"
	do
		waited=$((waited + 1))
		if [ "$waited" -ge "$MODEM_READY_TIMEOUT" ]; then
			log_step "Modem did not become ready within ${MODEM_READY_TIMEOUT}s."
			return 1
		fi
		sleep 1
	done
	return 0
}

power_cycle_modem() {
	log_step "Power-cycling modem..."
	until modem_cmd "AT+QPOWD" | grep -q "OK"
	do
		log_step "Modem reset command failed. Retrying..."
		sleep 1
	done

	log_step "Waiting ${QPOWD_REBOOT_WAIT}s for modem power cycle..."
	sleep "$QPOWD_REBOOT_WAIT"

	if ! wait_for_modem_ready; then
		return 1
	fi

	# Immediately force RF off after restart to prevent registration on old IMEI.
	local attempt=0
	while [ "$attempt" -lt 10 ]; do
		if modem_cmd "AT+CFUN=4" | grep -q "OK"; then
			return 0
		fi
		attempt=$((attempt + 1))
		sleep 1
	done
	log_step "Warning: could not apply CFUN=4 after modem power cycle."
	return 0
}

restart_modem() {
	log_step "Soft-resetting modem..."
	if modem_cmd "AT+CFUN=1,1" | grep -q "OK"; then
		log_step "Waiting ${MODEM_SOFT_RESTART_WAIT}s for soft restart..."
		sleep "$MODEM_SOFT_RESTART_WAIT"
	elif modem_cmd "AT+CFUN=1" | grep -q "OK"; then
		log_step "Waiting ${MODEM_SOFT_RESTART_WAIT}s after CFUN=1..."
		sleep "$MODEM_SOFT_RESTART_WAIT"
	else
		log_step "Soft modem restart command failed."
		return 1
	fi

	if ! wait_for_modem_ready; then
		return 1
	fi

	# Immediately force RF off after restart to prevent registration on old IMEI.
	local attempt=0
	while [ "$attempt" -lt 10 ]; do
		if modem_cmd "AT+CFUN=4" | grep -q "OK"; then
			return 0
		fi
		attempt=$((attempt + 1))
		sleep 1
	done
	log_step "Warning: could not apply CFUN=4 after soft modem restart."
	return 0
}

wait_for_sim_ready() {
	local waited=0
	local max_wait=60
	log_step "Waiting for SIM to become ready..."
	while [ "$waited" -lt "$max_wait" ]; do
		if get_sim_id >/dev/null 2>&1; then
			log_step "SIM is ready."
			return 0
		fi
		waited=$((waited + 1))
		sleep 1
	done
	log_step "SIM did not become ready within ${max_wait}s."
	return 1
}

generate_deterministic_imei() {
	local set_log

	# NOTE: The new IMEI is only readable after AT+QPOWD (full modem power cycle).
	# We verify via the AT+EGMR response ("IMEI has been successfully changed."),
	# not by reading the IMEI back here.
	set_log="$(timeout 60 python3 /lib/blue-merle/imei_generate.py -d 2>&1)"
	if [ $? -ne 0 ]; then
		logger -p notice -t blue-merle-rf-guard "Deterministic IMEI generation failed: $set_log"
		return 1
	fi

	if ! echo "$set_log" | grep -q "successfully changed"; then
		logger -p notice -t blue-merle-rf-guard "Deterministic IMEI AT command did not confirm success: $set_log"
		return 1
	fi

	log_step "Deterministic IMEI written (will be verified after modem power cycle)."
	return 0
}

apply_new_sim_flow() {
	local sim_id="$1"
	local imei

	log_step "Switching modem to RF-off to prevent IMSI/IMEI leakage."
	if ! set_rf_off; then
		log_step "Failed to disable RF (CFUN=4)."
		return 1
	fi

	log_step "Generating deterministic IMEI for inserted SIM."
	if ! generate_deterministic_imei; then
		log_step "Deterministic IMEI step failed. Keeping RF disabled."
		return 1
	fi

	log_step "Resetting APN settings for new SIM."
	reset_apn

	if ! restart_modem; then
		log_step "Modem restart failed after IMEI/APN update."
		return 1
	fi

	# Read IMEI after QPOWD — now the new value is visible.
	imei="$(read_imei_raw)"
	log_step "Deterministic IMEI verified after power cycle: ${imei}"

	mkdir -p /tmp/modem.1-1.2
	echo "$imei" > /tmp/modem.1-1.2/modem-imei
	if [ -d /root/esim ]; then
		echo "$imei" > /root/esim/imei
		shred -u /root/esim/log.txt >/dev/null 2>&1
	fi

	save_state "$sim_id" "$imei"
	STATE_SIM_ID="$sim_id"
	STATE_IMEI="$imei"
	STATE_EVER_SEEN_SIM="1"
	CURRENT_SIM_ID="$sim_id"
	SIM_REMOVED=0
	
	log_step "Re-enabling RF after successful IMEI change."
	if ! set_rf_on; then
		log_step "Warning: could not re-enable RF after IMEI change."
	fi

	log_step "Applying automatic APN profile."
	if ! apply_auto_apn; then
		log_step "Warning: automatic APN apply failed."
	fi
	
	log_step "SIM change flow completed successfully."
	return 0
}

handle_boot_gate() {
	local sim_id

	log_step "Boot gate started. Blocking RF until SIM/IMEI validation is complete."
	set_rf_off >/dev/null 2>&1
	load_state

	sim_id="$(get_sim_id 2>/dev/null)"
	if [ -z "$sim_id" ]; then
		if [ -z "$STATE_EVER_SEEN_SIM" ]; then
			log_step "Clean router boot detected and no SIM present yet. RF remains disabled."
		else
			log_step "SIM not present at boot. RF remains disabled until SIM is inserted."
		fi
		CURRENT_SIM_ID=""
		SIM_REMOVED=1
		return 0
	fi

	if [ -n "$STATE_SIM_ID" ] && [ "$sim_id" = "$STATE_SIM_ID" ]; then
		log_step "Known SIM detected at boot. Re-enabling RF."
		set_rf_on >/dev/null 2>&1
		CURRENT_SIM_ID="$sim_id"
		SIM_REMOVED=0
		return 0
	fi

	if [ -z "$STATE_EVER_SEEN_SIM" ]; then
		log_step "Clean router boot with first SIM insertion detected."
	else
		log_step "New SIM detected at boot. Deterministic IMEI update is required."
	fi

	if ! apply_new_sim_flow "$sim_id"; then
		SIM_REMOVED=1
		return 1
	fi
	return 0
}

monitor_loop() {
	local sim_id
	local removal_detected_at=0
	local last_recovery_at
	local now=0
	last_recovery_at="$(date +%s)"

	while true
	do
		now="$(date +%s)"
		sim_id="$(get_sim_id 2>/dev/null)"

		if [ -z "$sim_id" ]; then
			if [ "$SIM_REMOVED" -eq 0 ]; then
				log_step "SIM removed during runtime. Forcing RF-off mode."
				set_rf_off >/dev/null 2>&1
				SIM_REMOVED=1
				removal_detected_at="$now"
				last_recovery_at=0
			elif [ $((now - last_recovery_at)) -ge "$SIM_RECOVERY_INTERVAL" ]; then
				log_step "SIM still not visible. Power-cycling modem to probe SIM slot."
				if power_cycle_modem && wait_for_sim_ready; then
					sim_id="$(get_sim_id 2>/dev/null)"
					if [ -n "$sim_id" ]; then
						log_step "SIM detected after recovery cycle."
						last_recovery_at="$now"
						continue
					fi
				fi
				last_recovery_at="$now"
			fi
			sleep "$POLL_INTERVAL"
			continue
		fi

		# SIM detected after removal.
		if [ "$SIM_REMOVED" -eq 1 ]; then
			# If modem was just put into latched state by hot-removal,
			# do an immediate power cycle to recover SIM stack visibility.
			local time_since_removal=$(($(date +%s) - removal_detected_at))
			if [ "$time_since_removal" -lt 10 ]; then
				log_step "SIM detected shortly after removal. Modem may be latched. Doing power cycle..."
				if ! power_cycle_modem; then
					log_step "Modem restart failed. Retrying on next poll."
					sleep "$POLL_INTERVAL"
					continue
				fi
				if ! wait_for_sim_ready; then
					log_step "SIM not ready after modem restart. Retrying on next poll."
					sleep "$POLL_INTERVAL"
					continue
				fi
				sim_id="$(get_sim_id 2>/dev/null)"
			fi

			if [ -n "$CURRENT_SIM_ID" ] && [ "$sim_id" = "$CURRENT_SIM_ID" ]; then
				log_step "Previously used SIM reinserted. Re-enabling RF without IMEI change."
				set_rf_on >/dev/null 2>&1
				SIM_REMOVED=0
				sleep "$POLL_INTERVAL"
				continue
			fi

			log_step "SIM inserted after removal. Running deterministic IMEI flow."
			if ! apply_new_sim_flow "$sim_id"; then
				SIM_REMOVED=1
			fi
			sleep "$POLL_INTERVAL"
			continue
		fi

		if [ -n "$CURRENT_SIM_ID" ] && [ "$sim_id" != "$CURRENT_SIM_ID" ]; then
			log_step "SIM hot-swap detected during runtime."
			if ! apply_new_sim_flow "$sim_id"; then
				SIM_REMOVED=1
			fi
		fi

		sleep "$POLL_INTERVAL"
	done
}

main() {
	mkdir -p "$RUNTIME_DIR"
	exec 9>"$LOCK_FILE"
	if ! flock -n 9; then
		log_step "Another rf-guard instance is already running."
		exit 0
	fi

	handle_boot_gate
	monitor_loop
}

main "$@"
